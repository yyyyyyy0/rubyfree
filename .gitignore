# Swift / SwiftPM
.build/
.swiftpm/
Package.resolved

# Built app bundle (produced by Scripts/build-app.sh)
*.app
/dist/

# Xcode (not used, but guard against stray files)
*.xcodeproj
*.xcworkspace
*.dSYM

# macOS
.DS_Store

# S0 throwaway spikes (results recorded in issues, code is disposable)
/Spikes/

# Serena tooling state (per-machine, not project code)
/.serena/

# Dictionary SOURCE downloads (build-time only; generated TSVs under
# Sources/RubyfreeCore/Resources/ are committed, the raw XML is not)
/.dict-cache/

# Icon generation intermediate (final AppIcon.icns is committed)
/Scripts/AppIcon.iconset/
